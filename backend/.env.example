APP_ENV=development
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gpt-5
OPENAI_EXTRACTION_MODEL=gpt-5
DOWNLOAD_DIR=.cache/ma_mna_analyzer
REQUEST_TIMEOUT_SECONDS=180
CONNECT_TIMEOUT_SECONDS=20
MAX_SEARCH_RESULTS=8
MAX_CRAWL_PAGES=18
MAX_DOCUMENTS_PER_COMPANY=6
MAX_WEB_SNIPPETS_PER_COMPANY=4
MAX_PDF_BYTES=60000000
VERIFY_SSL=true
